# Copie para `.gitignore` na raiz do projeto.

# Segredos — NUNCA commitar. Mantém o .env.example (esse sim é versionado).
.env
.env.*
!.env.example

# Config local do Claude Code (a compartilhada .claude/settings.json vai; a local não)
.claude/settings.local.json

# Caixa de captura pessoal do /mss-spec:to-dolist — local, não versionada. A barra inicial
# ANCORA na raiz (sem ela, o padrão pegaria também commands/to-dolist.md, por casar por nome).
# Por não ser rastreada, o git não a toca ao trocar de branch → aparece em qualquer branch.
/to-dolist.md

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Saídas de run do CI (item 12) — artefatos efêmeros do pipeline, NUNCA commitar.
report.xml
coverage.xml
htmlcov/
.coverage

# Mapa mental (/mss-spec:mapa-neural) — saída derivada/regenerável, gerada em docs/. ANCORADO em
# /docs/ (com a barra): sem ela, o padrão casaria por nome e ignoraria o próprio commands/mapa-neural.md.
/docs/mapa-neural.html
/docs/mapa-neural.md

# Node / build do Tailwind (o static/css/app.css compilado FICA versionado)
node_modules/

# IDE / SO
.vscode/
.idea/
.DS_Store
Thumbs.db
